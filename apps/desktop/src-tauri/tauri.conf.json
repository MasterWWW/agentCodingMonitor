{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Monitor",
  "version": "0.1.0",
  "identifier": "com.vibemonitor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibe Monitor",
        "width": 120,
        "height": 36,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "visible": true,
        "skipTaskbar": false
      },
      {
        "label": "wizard",
        "title": "欢迎使用 Vibe Monitor",
        "url": "index.html",
        "width": 420,
        "height": 320,
        "resizable": false,
        "decorations": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
